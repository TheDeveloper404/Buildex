{
  "name": "buildex",
  "private": true,
  "version": "0.1.0",
  "description": "Procurement & Price Intelligence for Construction",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:reset": "npm run db:reset --workspace=apps/api",
    "test": "vitest",
    "test:components": "vitest run",
    "test:components:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:start": "npm run dev",
    "test:docker": "docker compose -f docker-compose.tests.yml up --build",
    "test:docker:vitest": "docker compose -f docker-compose.vitest.yml up --build",
    "test:docker:down": "docker compose -f docker-compose.tests.yml down -v",
    "test:docker:vitest:down": "docker compose -f docker-compose.vitest.yml down -v"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
