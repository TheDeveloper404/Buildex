# API Configuration
NODE_ENV=development
PORT_BASE=3100

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buildex
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Web Configuration
WEB_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:3101/api

# Cookie Settings
COOKIE_SECURE=false

# Dev Login — disable in production (DEV_LOGIN_ENABLED=false)
DEV_LOGIN_ENABLED=true

# Azure Communication Service (email) — required in production
# Get from: Azure Portal > Communication Service > Keys
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_SENDER_EMAIL=DoNotReply@yourdomain.com

# Azure Application Insights — optional, enables distributed tracing
APPLICATIONINSIGHTS_CONNECTION_STRING=
